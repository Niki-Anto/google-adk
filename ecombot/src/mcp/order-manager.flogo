      "ref": "#mcpserver",
      "name": "flogo-mcp-mcpsever",
      "description": "Flogo MCP server for Agentic AI",
      "settings": {
        "serverName": "=$property[\"MCP.serverName\"]",
        "serverVersion": "1.0.0",
        "serverType": "HTTP",
        "serverPort": "=$property[\"MCP.port\"]",
        "serverEndpointPath": "=$property[\"MCP.URI\"]",
        "enableTLS": false,
