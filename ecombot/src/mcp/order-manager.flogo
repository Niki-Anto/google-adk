      },
      "id": "MCPServer",
      "handlers": [
        {
          "description": "",
          "settings": {
            "handlerType": "Tool",
            "resourceUri": "",
            "handlerName": "=$property[\"TOOLS.GetOrderStatus.name\"]",
            "handlerDescription": "=$property[\"TOOLS.GetOrderStatus.description\"]"
          },
          "action": {
            "ref": "github.com/project-flogo/flow",
            "settings": {
              "flowURI": "res://flow:getOrderStatus"
            },
            "input": {
              "arguments": {
                "mapping": {
                  "order_id": "=$.arguments.order_id"
                }
              }
            },
            "output": {
              "response": {
                "mapping": {
                  "data": "=$.response.data",
                  "error": "=$.response.error"
                }
              }
            }
          },
          "schemas": {
            "reply": {
              "response": {
                "type": "json",
                "value": "{\r\n    \"type\": \"object\",\r\n  \"properties\": {\r\n    \"data\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"error\": {\r\n      \"type\": \"string\"\r\n    }\r\n }\r\n}",
                "fe_metadata": "{\r\n    \"type\": \"object\",\r\n  \"properties\": {\r\n    \"data\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"error\": {\r\n      \"type\": \"string\"\r\n    }\r\n }\r\n}"
              }
            },
